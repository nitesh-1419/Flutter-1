import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:volume_controller/volume_controller.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: OrientationVolumeDemo(),
    );
  }
}

class OrientationVolumeDemo extends StatefulWidget {
  @override
  _OrientationVolumeDemoState createState() => _OrientationVolumeDemoState();
}

class _OrientationVolumeDemoState extends State<OrientationVolumeDemo> {

  double volume = 0.5;

  @override
  void initState() {
    super.initState();

    VolumeController().getVolume().then((value) {
      setState(() {
        volume = value;
      });
    });
  }

  // Change to Portrait
  void setPortrait() {
    SystemChrome.setPreferredOrientations([
      DeviceOrientation.portraitUp,
    ]);
  }

  // Change to Landscape
  void setLandscape() {
    SystemChrome.setPreferredOrientations([
      DeviceOrientation.landscapeLeft,
      DeviceOrientation.landscapeRight,
    ]);
  }

  // Increase Volume
  void increaseVolume() {
    volume += 0.1;
    if (volume > 1) volume = 1;
    VolumeController().setVolume(volume);
    setState(() {});
  }

  // Decrease Volume
  void decreaseVolume() {
    volume -= 0.1;
    if (volume < 0) volume = 0;
    VolumeController().setVolume(volume);
    setState(() {});
  }

  @override
  Widget build(BuildContext context) {

    return Scaffold(
      appBar: AppBar(
        title: Text("Orientation & Volume Demo"),
      ),

      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [

            Text("Change Screen Orientation",
                style: TextStyle(fontSize: 20)),

            SizedBox(height: 10),

            ElevatedButton(
              onPressed: setPortrait,
              child: Text("Portrait Mode"),
            ),

            ElevatedButton(
              onPressed: setLandscape,
              child: Text("Landscape Mode"),
            ),

            SizedBox(height: 40),

            Text("Volume Control",
                style: TextStyle(fontSize: 20)),

            SizedBox(height: 10),

            ElevatedButton(
              onPressed: increaseVolume,
              child: Text("Increase Volume"),
            ),

            ElevatedButton(
              onPressed: decreaseVolume,
              child: Text("Decrease Volume"),
            ),
          ],
        ),
      ),
    );
  }
}
