import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: "ListTile and Switch Demo",
      home: ListTileSwitchDemo(),
    );
  }
}

class ListTileSwitchDemo extends StatefulWidget {
  @override
  _ListTileSwitchDemoState createState() => _ListTileSwitchDemoState();
}

class _ListTileSwitchDemoState extends State<ListTileSwitchDemo> {

  bool isSwitched = false;

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text("ListTile & Switch Example"),
      ),

      body: ListTile(
        leading: Icon(Icons.lightbulb),
        title: Text("Turn Light On / Off"),
        subtitle: Text(isSwitched ? "Light is ON" : "Light is OFF"),

        trailing: Switch(
          value: isSwitched,
          onChanged: (value) {
            setState(() {
              isSwitched = value;
            });
          },
        ),
      ),
    );
  }
}
